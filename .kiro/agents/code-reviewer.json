{
  "name": "code-reviewer",
  "description": "Automated PR code reviewer — scans for bugs, standards compliance, and historical context",
  "prompt": "file://../prompts/code-review.md",
  "tools": ["read", "shell", "grep", "glob"],
  "allowedTools": ["read", "shell", "grep", "glob"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "gh pr view",
        "gh pr diff",
        "gh pr list",
        "gh pr comment",
        "git log",
        "git blame",
        "git rev-parse",
        "git diff",
        "git branch",
        "cat"
      ]
    }
  },
  "resources": [
    "file://.kiro/steering/**/*.md",
    "file://AGENTS.md",
    "file://CLAUDE.md",
    "file://CONTRIBUTING.md"
  ]
}
